# =========================
#   3Proxy Docker ENV
#   Server:
# =========================
# Скопируй в .env и поменяй значения:  cp .env.example .env

IMAGE=ghcr.io/tarampampam/3proxy:2
CONTAINER_NAME=3proxy

# Внешний IP сервера, только для удобства/заметок
PROXY_HOST=0.0.0.0

# Авторизация
# ОБЯЗАТЕЛЬНО поменяй логин и пароль перед запуском.
# Пустые логин/пароль = прокси без авторизации (открыт для всех) — не делай так на публичном IP.
PROXY_LOGIN=User
PROXY_PASSWORD=Password

# Порты
# HTTP/HTTPS proxy:
PROXY_PORT=3128

# SOCKS5 proxy:
SOCKS_PORT=1080

# DNS
PRIMARY_RESOLVER=1.1.1.1
SECONDARY_RESOLVER=8.8.8.8

# Лимиты
MAX_CONNECTIONS=1024
# Размер DNS-кэша. Работает только при сборке из этого репо (build:), не в пребилт-образе.
DNS_CACHE_SIZE=65536

# Логи
LOG_OUTPUT=/dev/stdout

# Дополнительные пользователи, если нужны.
# Формат для этого образа — JSON-объект: {"login2":"pass2","login3":"pass3"}
# Пусто = нет доп. пользователей.
EXTRA_ACCOUNTS=

# Дополнительные строки конфига 3proxy (через \n)
EXTRA_CONFIG=

# Дополнительные аргументы для proxy/socks.
# Работают только при сборке из этого репо (build:), не в пребилт-образе.
PROXY_EXTRA_ARGS=
SOCKS_EXTRA_ARGS=
